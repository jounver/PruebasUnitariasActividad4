    {
      "name": "PC-3 # Visualización de todos los monitores disponibles en la web",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Comprobar si el estado de la respuesta es 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Comprobar que el numero de monitores disponibles es 2\", function () {\r",
              "    pm.expect(2).to.eql(jsonData.Items.length);\r",
              "});\r",
              "\r",
              "pm.test(\"Comprobando el contenido de la respuesta\", function () {\r",
              "     for(var i=0 ; i< jsonData.Items.length ; i++){\r",
              "        var item = jsonData.Items[i];\r",
              "\r",
              "        pm.expect(\"monitor\").equals(jsonData.Items[i].cat);\r",
              "        \r",
              "        pm.expect(item.desc).is.not.empty; \r",
              "        pm.expect(item.desc).length.greaterThan(20);\r",
              "        \r",
              "        pm.expect(item.img).contains(\"/\");\r",
              "        pm.expect(item.img).contains(\".jpg\");\r",
              "                 \r",
              "        pm.expect(item.price).greaterThan(200);\r",
              "        \r",
              "        pm.expect(item.title).is.not.empty;\r",
              "     }\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {}
          }
        }
      ],
